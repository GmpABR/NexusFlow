# .gitignore for NexusFlow (Dotnet + React)

# .NET
[Bb]in/
[Oo]bj/
*.user
*.userosscache
*.sln.docstates
.vs/
.vscode/
*.db
*.db-journal

# Secrets (NEVER commit real values)
appsettings.Development.json

# Node / React
node_modules/
dist/
dist-ssr/
*.local
.eslintcache
.stylelintcache
node_modules.zip
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

# OS/System
.DS_Store
Thumbs.db

# Environment Variables
.env
.env.development
.env.local
.env.production
.env.test

# Debug / Temp files (should never be committed)
git_status.txt
register_error.json
test_reg.js
fix_db.sql
*.sql
testAi.ts
